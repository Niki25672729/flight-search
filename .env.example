# Copy this file to .env (gitignored) and fill in real values.
# Read by docker-compose.yml for the Airflow stack and the ingestion container.

FLIGHT_SEARCH_GCS_BUCKET=your-bucket-name
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: silver prefix the processing job writes to. Defaults to the real "silver";
# set to silver_manual_test to target the dev fixture instead.
# SILVER_GCS_PREFIX=silver
